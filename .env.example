ADMIN_KEY=change-me-in-env
ADMIN_TOKEN_TTL_MINUTES=480
# Option A (single DSN):
# MYSQL_URL=mysql://user:password@127.0.0.1:3306/local_chat_server

# Option B (MariaDB/MySQL split fields):
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=local_chat_server

# Optional Sentry monitoring:
# SENTRY_DSN=https://public@o0.ingest.sentry.io/0
# NEXT_PUBLIC_SENTRY_DSN=https://public@o0.ingest.sentry.io/0
# SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_ENVIRONMENT=development
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# SENTRY_SUPPRESS_GLOBAL_ERROR_HANDLER_FILE_WARNING=1